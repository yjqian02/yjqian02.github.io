@article{muller2025family,
 abstract = {BACKGROUND: Penetrance and risk of ventricular arrhythmias (VAs) in arrhythmogenic right ventricular cardiomyopathy (ARVC) are increasingly recognized as being genotype specific. Therefore, genotype-informed family screening protocols may lead to safer and more personalized recommendations than the current one-size-fits-all screening recommendations. We aimed to develop a safe, evidence-based plakophilin-2 (PKP2)–specific longitudinal screening algorithm. METHODS: We included 295 relatives (41% male; age 30.9 years [18.0–47.7 years]) with a pathogenic or likely pathogenic PKP2 variant from 145...},
 author = {MD Steven A. Muller and J. Hopkins and Arvc Program and MD Babken Asatryan and PhD Alessio Gasperetti and PhD Maarten and MD J. Cramer and P. Amin and Peter Loh and PhD Richard T. Carrick and PhD Moniek G.P.J. Cox and Priya Md and PhD Marish and MD PhD I.F.J. Oerlemans and Mgc RN Crystal Tichnell and MD PhD Sing-Chien Yap and MS Cgc Brittney Murray and MD Stefan L. Zimmerman and MD PhD Hugh Peter van Tintelen and M. Calkins and MD te Riele and PhD Cynthia A. James},
 doi = {10.1161/CIRCULATIONAHA.125.074058},
 journal = {Circulation},
 pages = {313 - 326},
 title = {Family Screening in Relatives at Risk for Plakophilin-2–Associated Arrhythmogenic Right Ventricular Cardiomyopathy},
 volume = {152},
 year = {2025}
}
